# Copy this file to .env and fill in your keys

# OpenAI API key (for the LLM calls)
OPENAI_API_KEY=

# Pydantic AI model. The course default is openai:gpt-5.4-mini.
PYDANTIC_AI_MODEL=openai:gpt-5.4-mini

# Service name used to identify this homework run in Logfire queries.
LOGFIRE_SERVICE_NAME=llm-zoomcamp-dlt-homework

# Logfire write token (created in Question 1)
# Get it from https://logfire.dev/dashboard
LOGFIRE_TOKEN=

# Logfire read token (created in Question 2)
LOGFIRE_READ_TOKEN=
